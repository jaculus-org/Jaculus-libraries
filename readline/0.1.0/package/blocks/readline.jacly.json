                }
            ],
            "isProgramStart": true,
            "tooltip": "%T%",
            "code": "{\n\tconst streamReadline = new readline($[ECHO]);\n\tasync function streamOnLineLoop() {\n\t\ttry {\n\t\t\tconst line = await streamReadline.read();\n$[CODE]\n\t\t\tstreamOnLineLoop();\n\t\t} catch (_reason) {\n\t\t\tconsole.warn(\"stdin line read failed:\", _reason);\n\t\t\tstreamOnLineLoop();\n\t\t}\n\t}\n\tstreamOnLineLoop();\n}"
        },
        {
            "kind": "block",
            "type": "readline_keyValue",
            "message0": "%T%",
            "args0": [
                {
                    "type": "field_dropdown",
                    "name": "ECHO",
                    "options": [
                        ["%ECHO_OFF%", "false"],
                        ["%ECHO_ON%", "true"]
                    ]
                },
