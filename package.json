{
    "name": "jaculus-libraries-core",
    "version": "0.1.0",
    "description": "Core libraries for the Jaculus - JavaScript runtime for embedded devices",
    "license": "MIT",
    "author": "Jaculus team",
    "type": "module",
    "packageManager": "pnpm@11.0.9",
    "scripts": {
