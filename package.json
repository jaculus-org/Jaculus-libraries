        "build-libs": "pnpm run -r build",
        "clean-libs": "pnpm run -r clean",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "prettier": "3.8.3"
    },
    "dependencies": {
        "copyfiles": "^2.4.1",
        "typescript": "^6.0.3"
    }
}
