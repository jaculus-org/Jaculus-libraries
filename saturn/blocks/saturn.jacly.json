{
    "$schema": "https://jacly.jaculus.org/schema.json",
    "package": "saturn",
    "category": "saturn",
    "name": "%T%",
    "description": "%T%",
    "colour": "#4B9CD3",
    "icon": "CircuitBoard",
    "priority": 140,
    "import": ["import { createSaturn, SaturnPins } from \"saturn\";"],
    "contents": [
        {
            "kind": "label",
            "text": "%SETUP%"
        },
        {
            "kind": "block",
            "type": "saturn_constructor",
            "message0": "%T%",
            "args0": [
                {
                    "type": "field_input",
                    "name": "CONSTRUCTED_VAR_NAME",
                    "text": "saturn_?"
                },
                {
                    "type": "field_dropdown",
                    "name": "FLIP",
                    "options": [
                        ["%FALSE%", "false"],
                        ["%TRUE%", "true"]
                    ]
                }
            ],
            "constructs": "saturn",
            "virtualInstances": [
                {
                    "instanceof": "rphub75_display",
                    "name": "display",
                    "connection": "$[CONSTRUCTED_VAR_NAME].display"
                }
            ],
            "tooltip": "%T%",
            "code": "$[CONSTRUCTED_VAR_NAME] = createSaturn($[FLIP]);",
            "previousStatement": null,
            "nextStatement": null
        },
        {
            "kind": "label",
            "text": "%PINS%"
        },
