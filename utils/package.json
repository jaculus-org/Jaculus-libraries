{
    "name": "utils",
    "version": "0.1.0",
    "author": "Jakub Andrysek",
    "license": "MIT",
    "description": "Jaculus utilities library (scaling, clamping, mapping, etc.)",
    "type": "module",
    "main": "build/js/index.js",
    "types": "build/types/index.d.ts",
    "files": [
        "build/**/*"
    ],
    "scripts": {
        "install": "jac lib-install",
        "build-no-check": "jac lib-build --no-check",
        "build": "jac lib-build",
        "clean": "rm -rf build"
    },
    "jaculus": {
        "packageFormat": 1,
        "blocks": "blocks"
    }
}
