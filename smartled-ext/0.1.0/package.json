{
  "name": "smartled-ext",
  "version": "0.1.0",
  "description": "Extended SmartLED utility functions and types",
  "dependencies": {
    "@types/jaculus": "0.1.0",
    "colors": "0.1.0"
  },
  "files": [
    "build/**/*"
  ],
  "type": "module",
  "main": "build/js/index.js",
  "scripts": {
    "install": "jac lib-install",
    "build-no-check": "jac lib-build --no-check",
    "build": "jac lib-build",
    "clean": "rm -rf build"
  },
  "types": "build/types/index.d.ts",
  "jaculus": {
    "packageFormat": 1,
    "blocks": "blocks"
  },
